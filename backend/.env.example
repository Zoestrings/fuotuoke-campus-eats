# MySQL Database Connection
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=fuotuoke_campus_eats
DB_PORT=3306

# JWT Secrets
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# JWT Claims (issuer + audience prevent cross-service token replay)
JWT_ISSUER=fuotuoke-campus-eats
JWT_AUDIENCE=fuo-app

# Paystack Sandbox Keys (Use Paystack Test Keys)
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key

# Server Config
PORT=5000
NODE_ENV=development

# Frontend Client URL (for CORS)
CLIENT_URL=http://localhost:3000
